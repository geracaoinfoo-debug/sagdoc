{
    "name": "dga/sagdoc",
    "description": "Sistema de Apoio a Gestao Documental Aduaneira - DGA Guine-Bissau",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "ext-openssl": "*",
        "phpmailer/phpmailer": "^6.9",
        "firebase/php-jwt": "^7.0",
        "monolog/monolog": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/validation.php",
            "app/Helpers/format.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
